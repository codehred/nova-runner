# Puerto del servidor
PORT=4000

# Entorno: development | production | test
NODE_ENV=development

# Secreto para firmar JWT (cambia esto en producción, usa un valor largo y aleatorio)
JWT_SECRET=change-this-super-secret-value

# Tiempo de expiración del token
JWT_EXPIRES_IN=7d

# Ruta del archivo SQLite (usa :memory: para pruebas)
DB_PATH=./data/nova-runner.db

# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN=http://localhost:5173
